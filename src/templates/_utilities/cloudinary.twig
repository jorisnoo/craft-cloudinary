<div class="flex flex-nowrap" style="justify-content: space-between; align-items: center;">
    <h2 style="margin: 0;">{{ 'Volumes'|t('cloudinary') }}</h2>

    {% if volumes|length %}
        <form method="post" accept-charset="UTF-8">
            {{ csrfInput() }}
            {{ actionInput('cloudinary/sync') }}
            {{ redirectInput('utilities/cloudinary') }}
            <button type="submit" class="btn submit">{{ 'Sync now'|t('cloudinary') }}</button>
        </form>
    {% endif %}
</div>

{% if volumes|length %}
    <table class="data fullwidth" style="margin-top: 14px;">
        <thead>
            <tr>
                <th>{{ 'Volume'|t('cloudinary') }}</th>
                <th>{{ 'Cloud Name'|t('cloudinary') }}</th>
                <th>{{ 'Assets'|t('cloudinary') }}</th>
            </tr>
        </thead>
        <tbody>
            {% for volume in volumes %}
                <tr>
                    <td><strong>{{ volume.name }}</strong> <span class="light">({{ volume.handle }})</span></td>
                    <td><code>{{ volume.cloudName }}</code></td>
                    <td>{{ volume.assetCount|number }}</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
{% else %}
    <p class="light">{{ 'No Cloudinary volumes configured.'|t('cloudinary') }}</p>
{% endif %}

<hr>

<h2>API Rate Limits</h2>

{% if rateLimits|length %}
    <table class="data fullwidth">
        <thead>
            <tr>
                <th>{{ 'Volume'|t('cloudinary') }}</th>
                <th>{{ 'Remaining'|t('cloudinary') }}</th>
                <th>{{ 'Resets At'|t('cloudinary') }}</th>
            </tr>
        </thead>
        <tbody>
            {% for limit in rateLimits %}
                <tr>
                    <td><strong>{{ limit.volumeName }}</strong></td>
                    {% if limit.error is defined %}
                        <td colspan="2" class="error">{{ limit.error }}</td>
                    {% else %}
                        <td>{{ limit.remaining|number }} / {{ limit.allowed|number }}</td>
                        <td>{{ limit.resetAt ?? '---' }}</td>
                    {% endif %}
                </tr>
            {% endfor %}
        </tbody>
    </table>
{% else %}
    <p class="light">{{ 'No Cloudinary volumes configured.'|t('cloudinary') }}</p>
{% endif %}

<hr>

<h2>Recent Webhooks</h2>

{% if webhooks|length %}
    <table class="data fullwidth">
        <thead>
            <tr>
                <th>{{ 'Date'|t('cloudinary') }}</th>
                <th>{{ 'Type'|t('cloudinary') }}</th>
                <th>{{ 'Public ID'|t('cloudinary') }}</th>
            </tr>
        </thead>
        <tbody>
            {% for entry in webhooks %}
                <tr>
                    <td>{{ entry.processedAt|datetime('short') }}</td>
                    <td><code>{{ entry.notificationType }}</code></td>
                    <td>{{ entry.publicId ?? '---' }}</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
{% else %}
    <p class="light">{{ 'No recent webhook activity.'|t('cloudinary') }}</p>
{% endif %}
