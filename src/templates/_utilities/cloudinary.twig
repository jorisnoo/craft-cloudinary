<h2>Volumes</h2>

{% if volumes|length %}
    <table class="data fullwidth">
        <thead>
            <tr>
                <th>{{ 'Volume'|t('cloudinary') }}</th>
                <th>{{ 'Cloud Name'|t('cloudinary') }}</th>
                <th>{{ 'Assets'|t('cloudinary') }}</th>
            </tr>
        </thead>
        <tbody>
            {% for volume in volumes %}
                <tr>
                    <td><strong>{{ volume.name }}</strong> <span class="light">({{ volume.handle }})</span></td>
                    <td><code>{{ volume.cloudName }}</code></td>
                    <td>{{ volume.assetCount|number }}</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
{% else %}
    <p class="light">{{ 'No Cloudinary volumes configured.'|t('cloudinary') }}</p>
{% endif %}

<hr>

<h2>Recent Webhooks</h2>

{% if webhooks|length %}
    <table class="data fullwidth">
        <thead>
            <tr>
                <th>{{ 'Date'|t('cloudinary') }}</th>
                <th>{{ 'Type'|t('cloudinary') }}</th>
                <th>{{ 'Public ID'|t('cloudinary') }}</th>
            </tr>
        </thead>
        <tbody>
            {% for entry in webhooks %}
                <tr>
                    <td>{{ entry.processedAt|datetime('short') }}</td>
                    <td><code>{{ entry.notificationType }}</code></td>
                    <td>{{ entry.publicId ?? '---' }}</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
{% else %}
    <p class="light">{{ 'No recent webhook activity.'|t('cloudinary') }}</p>
{% endif %}
