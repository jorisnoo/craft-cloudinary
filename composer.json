{
    "name": "jorisnoo/craft-cloudinary",
    "description": "Cloudinary integration for Craft CMS.",
    "type": "craft-plugin",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "cloudinary/cloudinary_php": "^3.1.0",
        "craftcms/cms": "^5.0.0",
        "thomasvantuycom/flysystem-cloudinary": "^2.0.2",
        "craftcms/flysystem": "^2.0.0"
    },
    "require-dev": {
        "craftcms/ecs": "dev-main",
        "craftcms/phpstan": "dev-main",
        "pestphp/pest": "^3.8"
    },
    "autoload": {
        "psr-4": {
            "Noo\\CraftCloudinary\\": "src/"
        }
    },
    "extra": {
        "handle": "cloudinary",
        "name": "Cloudinary",
        "developer": "Joris Noordermeer",
        "documentationUrl": "https://github.com/jorisnoo/craft-cloudinary",
        "class": "Noo\\CraftCloudinary\\Cloudinary",
        "packageName": "jorisnoo/craft-cloudinary"
    },
    "scripts": {
        "check-cs": "ecs check --ansi",
        "fix-cs": "ecs check --ansi --fix"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "yiisoft/yii2-composer": true,
            "craftcms/plugin-installer": true,
            "pestphp/pest-plugin": true
        }
    }
}
